# VITE_STELLAR_NETWORK — default network shown on first load (testnet | mainnet)
# Users can toggle the network in the UI; this only sets the initial value.
# Testnet (default):
VITE_STELLAR_NETWORK=testnet
# Mainnet:
# VITE_STELLAR_NETWORK=mainnet

# VITE_REQUEST_SIGNING_SECRET — Stellar secret key used by the browser to sign backend POST requests.
# Its public key must be listed in backend REQUEST_SIGNING_PUBLIC_KEYS outside local development.
VITE_REQUEST_SIGNING_SECRET=S...
